# JWT 签名密钥, 本地开发可使用占位值, 非本地环境请使用随机强密钥
JWT_SECRET=replace-with-local-secret

# 管理员初始用户名
ADMIN_USERNAME=admin

# 管理员初始密码的 BCrypt 哈希, 不要写入明文密码, Docker Compose 部署时建议用单引号包住哈希
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash

# 密码哈希强度, 本地开发默认 10, 生产环境建议 12 以上
PASSWORD_BCRYPT_STRENGTH=10

# 应用运行环境, local 表示本机开发
APP_ENV=local

# Spring 激活配置, 本机开发使用 local
SPRING_PROFILES_ACTIVE=local

# 后端服务端口
SERVER_PORT=8080

# Docker Compose 暴露的前端访问端口, 例如 http://localhost:8088
HTTP_PORT=8088

# 前端开发服务器地址, 用于 CORS 和回调
WEB_BASE_URL=http://localhost:5173

# 后端 API 基础地址, 供前端开发环境使用
API_BASE_URL=http://localhost:8080

# Vite 应用名称
VITE_APP_NAME=CreatorSpace

# Vite 应用环境
VITE_APP_ENV=local

# Vite 客户端 API 基础地址, 留空时使用同源 /api
VITE_API_BASE_URL=

# Vite 客户端请求超时时间, 单位毫秒
VITE_API_TIMEOUT_MS=15000

# Vite 开发代理目标, 本机开发默认指向后端
VITE_API_PROXY_TARGET=http://localhost:8080

# Vite 开发服务器端口
VITE_DEV_SERVER_PORT=5173

# Vite 开发服务器监听地址, Docker/局域网调试可改为 0.0.0.0
VITE_DEV_SERVER_HOST=127.0.0.1

# 前端单文件上传大小上限, 单位 MB
VITE_UPLOAD_MAX_FILE_SIZE_MB=20

# hCaptcha 站点 Key, 当前仅预留配置, 接入验证码功能后由前端读取
VITE_HCAPTCHA_SITE_KEY=

# 允许跨域来源或来源模式, 本地开发使用 * 全开放
CORS_ALLOWED_ORIGINS=*

# JWT 访问令牌有效期, 单位分钟
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120

# JWT 刷新令牌有效期, 单位天
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# PostgreSQL 主机
POSTGRES_HOST=127.0.0.1

# PostgreSQL 端口
POSTGRES_PORT=5432

# PostgreSQL 数据库名
POSTGRES_DB=creatorspace

# PostgreSQL 用户名
POSTGRES_USERNAME=postgres

# PostgreSQL 密码, 本地直连可留空, Docker Compose 部署必须填写
POSTGRES_PASSWORD=

# Redis 主机
REDIS_HOST=127.0.0.1

# Redis 端口
REDIS_PORT=6379

# Redis 数据库编号
REDIS_DATABASE=0

# Redis 密码, 本地和 Docker Compose 部署都可留空；生产环境建议填写强密码
REDIS_PASSWORD=

# 文件存储类型, 当前默认使用本机相对路径
FILE_STORAGE_TYPE=local

# 本机文件存储根目录, 相对项目根目录
LOCAL_FILE_STORAGE_ROOT=storage/uploads

# 上传文件公开访问前缀, 由后端静态资源映射使用
LOCAL_FILE_PUBLIC_PREFIX=/uploads

# 单个上传文件大小上限
UPLOAD_MAX_FILE_SIZE=20MB

# 单次请求上传大小上限
UPLOAD_MAX_REQUEST_SIZE=50MB

# 单个上传文件大小上限, 单位 MB, 供业务配置读取
UPLOAD_MAX_FILE_SIZE_MB=20

# 单次请求上传大小上限, 单位 MB, 供业务配置读取
UPLOAD_MAX_REQUEST_SIZE_MB=50

# AI 功能开关, 默认关闭
AI_ENABLED=false

# 大模型供应商, 默认预留智谱 AI
AI_PROVIDER=zhipu

# 智谱开放平台 API 地址
ZHIPU_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 智谱 API Key, 本机按需填写
ZHIPU_API_KEY=

# 智谱模型, 用于摘要、标签和后续 AI 任务
ZHIPU_MODEL=glm-4v-flash

# 智谱多模态模型, 新版配置兼容项；未单独配置 ZHIPU_MODEL 时后端可使用该值
ZHIPU_MULTIMODAL_MODEL=glm-4.1v-thinking-flash

# 智谱请求超时时间, 单位秒
ZHIPU_REQUEST_TIMEOUT_SECONDS=60

# 智谱最大输出长度, 单位 token
ZHIPU_MAX_OUTPUT_TOKENS=4096

# 智谱思考模式开关, 默认关闭以控制响应延迟
ZHIPU_THINKING_ENABLED=false

# hCaptcha 验证码站点密钥
HCAPTCHA_SITE_KEY=

# hCaptcha 验证码密钥, 仅后端使用
HCAPTCHA_SECRET_KEY=
