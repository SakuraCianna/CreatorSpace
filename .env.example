# JWT 签名密钥, 本地开发请使用随机强密钥
JWT_SECRET=replace-with-local-secret

# 管理员初始用户名
ADMIN_USERNAME=admin

# 管理员初始密码的 BCrypt 哈希, 不要写入明文密码
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash

# 管理员密码哈希强度
ADMIN_PASSWORD_BCRYPT_STRENGTH=12

# 本机文件存储根目录, 可按开发机路径调整
LOCAL_FILE_STORAGE_ROOT=E:/CodeHome/CreatorSpace/storage/uploads
