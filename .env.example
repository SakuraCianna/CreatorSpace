# JWT 签名密钥, 本地开发请使用随机强密钥
JWT_SECRET=replace-with-local-secret

# 管理员初始用户名
ADMIN_USERNAME=admin

# 管理员初始密码的 BCrypt 哈希, 不要写入明文密码
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash

# 密码哈希强度, 适用于普通用户和管理员
PASSWORD_BCRYPT_STRENGTH=12

# 应用运行环境, local 表示本机开发
APP_ENV=local

# Spring 激活配置, 本机开发使用 local
SPRING_PROFILES_ACTIVE=local

# 后端服务端口
SERVER_PORT=8080

# 前端开发服务器地址, 用于 CORS 和回调
WEB_BASE_URL=http://localhost:5173

# 后端 API 基础地址, 供前端开发环境使用
API_BASE_URL=http://localhost:8080

# Vite 客户端 API 基础地址, 留空时使用同源 /api
VITE_API_BASE_URL=

# Vite 开发代理目标, 本机开发默认指向后端
VITE_API_PROXY_TARGET=http://localhost:8080

# 允许跨域来源, 多个来源使用英文逗号分隔
CORS_ALLOWED_ORIGINS=http://localhost:5173

# JWT 访问令牌有效期, 单位分钟
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120

# JWT 刷新令牌有效期, 单位天
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# PostgreSQL 主机
POSTGRES_HOST=127.0.0.1

# PostgreSQL 端口
POSTGRES_PORT=5432

# PostgreSQL 数据库名
POSTGRES_DB=creatorspace

# PostgreSQL 用户名
POSTGRES_USERNAME=creatorspace

# PostgreSQL 密码, 本机未设置时留空
POSTGRES_PASSWORD=

# Redis 主机
REDIS_HOST=127.0.0.1

# Redis 端口
REDIS_PORT=6379

# Redis 数据库编号
REDIS_DATABASE=0

# Redis 密码, 本机未设置时留空
REDIS_PASSWORD=

# 文件存储类型, 第一阶段使用本机相对路径
FILE_STORAGE_TYPE=local

# 本机文件存储根目录, 相对项目根目录
LOCAL_FILE_STORAGE_ROOT=storage/uploads

# 上传文件公开访问前缀, 由后端静态资源映射使用
LOCAL_FILE_PUBLIC_PREFIX=/uploads

# 单个上传文件大小上限, 单位 MB
UPLOAD_MAX_FILE_SIZE_MB=20

# 单次请求上传大小上限, 单位 MB
UPLOAD_MAX_REQUEST_SIZE_MB=50

# AI 功能开关, 第一阶段默认关闭
AI_ENABLED=false

# 大模型供应商, 默认预留智谱 AI
AI_PROVIDER=zhipu

# 智谱开放平台 API 地址
ZHIPU_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 智谱 API Key, 本机按需填写
ZHIPU_API_KEY=

# 智谱免费多模态模型
ZHIPU_MULTIMODAL_MODEL=glm-4.6v-flash

# 智谱文本模型, 用于摘要和标签等纯文本任务
ZHIPU_TEXT_MODEL=glm-4.7-flash

# 智谱请求超时时间, 单位秒
ZHIPU_REQUEST_TIMEOUT_SECONDS=60

# 智谱最大输出长度, 单位 token
ZHIPU_MAX_OUTPUT_TOKENS=4096

# 智谱思考模式开关, 默认关闭以控制响应延迟
ZHIPU_THINKING_ENABLED=false
