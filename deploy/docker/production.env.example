# Compose 项目名称, 用于隔离容器和卷名称
COMPOSE_PROJECT_NAME=creatorspace

# 对外 HTTP 端口, 本机已有 80 端口占用时可改为 8088
HTTP_PORT=80

# 应用运行环境
APP_ENV=production

# Spring 激活配置
SPRING_PROFILES_ACTIVE=production

# 后端内部端口, Docker Compose 内部固定使用 8080
SERVER_PORT=8080

# 站点公网地址, 用于生成页面链接和后台配置
WEB_BASE_URL=http://localhost

# API 公网地址, Nginx 同源反代时通常与 WEB_BASE_URL 一致
API_BASE_URL=http://localhost

# 允许跨域来源, 多个来源使用英文逗号分隔
CORS_ALLOWED_ORIGINS=http://localhost

# JWT 签名密钥, 生产环境必须使用至少 32 位随机强密钥
JWT_SECRET=replace-with-at-least-32-random-characters

# 管理员初始用户名
ADMIN_USERNAME=admin

# 管理员初始密码 BCrypt 哈希, 不要写入明文密码
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash

# 密码哈希强度
PASSWORD_BCRYPT_STRENGTH=12

# JWT 访问令牌有效期, 单位分钟
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120

# JWT 刷新令牌有效期, 单位天
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# PostgreSQL 数据库名
POSTGRES_DB=creatorspace

# PostgreSQL 用户名
POSTGRES_USERNAME=creatorspace

# PostgreSQL 密码, 生产环境必须使用随机强密码
POSTGRES_PASSWORD=replace-with-postgres-password

# Redis 数据库编号
REDIS_DATABASE=0

# Redis 密码, 生产环境必须使用随机强密码
REDIS_PASSWORD=replace-with-redis-password

# Vite 客户端 API 基础地址, 留空表示同源 /api
VITE_API_BASE_URL=

# Vite 客户端请求超时时间, 单位毫秒
VITE_API_TIMEOUT_MS=15000

# 前端单文件上传大小上限, 单位 MB
VITE_UPLOAD_MAX_FILE_SIZE_MB=20

# 单个上传文件大小上限
UPLOAD_MAX_FILE_SIZE=20MB

# 单次请求上传大小上限
UPLOAD_MAX_REQUEST_SIZE=50MB

# 单个上传文件大小上限, 单位 MB
UPLOAD_MAX_FILE_SIZE_MB=20

# 单次请求上传大小上限, 单位 MB
UPLOAD_MAX_REQUEST_SIZE_MB=50

# JVM 参数, 容器内按内存百分比控制堆大小
JAVA_OPTS=-XX:MaxRAMPercentage=75 -XX:+UseContainerSupport

# AI 功能开关, 默认关闭
AI_ENABLED=false

# 大模型供应商
AI_PROVIDER=zhipu

# 智谱开放平台 API 地址
ZHIPU_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 智谱 API Key, 未启用 AI 时留空
ZHIPU_API_KEY=

# 智谱多模态模型
ZHIPU_MULTIMODAL_MODEL=glm-4.6v-flash

# 智谱文本模型
ZHIPU_TEXT_MODEL=glm-4.7-flash

# 智谱请求超时时间, 单位秒
ZHIPU_REQUEST_TIMEOUT_SECONDS=60

# 智谱最大输出长度, 单位 token
ZHIPU_MAX_OUTPUT_TOKENS=4096

# 智谱思考模式开关
ZHIPU_THINKING_ENABLED=false
